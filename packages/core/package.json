{
  "$schema": "https://json.schemastore.org/package",
  "name": "@querylang/core",
  "version": "0.0.0",
  "license": "MIT",
  "private": false,
  "description": "Configurable search query language parser",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "prepack": "npm run build",
    "bundle": "mkdir -p artifacts && npm pack --pack-destination ./artifacts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "dependencies": {
    "chevrotain": "12.0.0"
  }
}
